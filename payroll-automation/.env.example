# Copy this file to .env and fill in real values.

# PostgreSQL connection string: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payroll_automation

# Port the backend listens on (defaults to 5000 if unset)
PORT=5000

# UC-001 roster source: the Google Sheet published as CSV.
# In Google Sheets: File > Share > Publish to web > select the roster tab + CSV,
# then paste the generated link here.
ROSTER_SHEET_CSV_URL=

# Secret used to sign JWT session tokens (auth). Use a long random string;
# every teammate can use their own value locally.
APP_SECRET=
